# ============================================================
# PRATISIG CONSULTING SERVICE - Environment Variables Template
# ============================================================
# Copier ce fichier en .env.local et remplir les valeurs

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Pratisig Consulting Service"

# Auth (Auth.js v5)
AUTH_SECRET=your-super-secret-key-minimum-32-chars
AUTH_URL=http://localhost:3000

# Google OAuth (optionnel)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/pratisig_db"

# Upload (Cloudinary ou Supabase Storage)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Wave Sénégal
WAVE_API_KEY=
WAVE_MERCHANT_ID=
WAVE_WEBHOOK_SECRET=

# Orange Money Sénégal
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_WEBHOOK_SECRET=

# Yash Money
YASH_MONEY_API_KEY=

# Kapey
KAPEY_API_KEY=

# Maps (Leaflet est gratuit, Mapbox optionnel)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Email (pour notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="noreply@pratisig.sn"

# Rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
