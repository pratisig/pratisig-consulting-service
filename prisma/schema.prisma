// ============================================================
// PRATISIG CONSULTING SERVICE - Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTHENTIFICATION & UTILISATEURS
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISEUR
  AGENT
  GERANT
  CAISSIER
  PROPRIETAIRE
  LIVREUR
  CLIENT
  PUBLIC
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  BANNED
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          Role       @default(CLIENT)
  status        UserStatus @default(PENDING)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations Auth.js
  accounts      Account[]
  sessions      Session[]

  // Relations métier
  biens          BienImmobilier[] @relation("ProprietaireBien")
  demandesImmo   DemandeImmo[]
  transactions   Transaction[]
  commandes      Commande[]
  livraisonsClient Livraison[] @relation("ClientLivraison")
  livraisonsLivreur Livraison[] @relation("LivreurLivraison")
  ventesAlimentation VenteAlimentation[]
  auditLogs      AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ============================================================
// MODULE 1 - IMMOBILIER
// ============================================================

enum TypeBien {
  APPARTEMENT
  MAISON
  VILLA
  TERRAIN
  BUREAU
  COMMERCE
  ENTREPOT
}

enum StatutBien {
  DISPONIBLE
  LOUE
  VENDU
  RESERVE
  INDISPONIBLE
}

enum TypeTransaction {
  LOCATION
  VENTE
  GERANCE
}

model BienImmobilier {
  id            String        @id @default(cuid())
  titre         String
  description   String
  type          TypeBien
  statut        StatutBien    @default(DISPONIBLE)
  transactionType TypeTransaction
  prix          Float
  surface       Float?
  nbChambres    Int?
  nbSallesDeBain Int?
  etage         Int?
  adresse       String
  ville         String
  quartier      String?
  latitude      Float?
  longitude     Float?
  photos        String[]      // URLs
  caracteristiques Json?      // { piscine: true, garage: true, ... }
  proprietaireId String
  proprietaire  User          @relation("ProprietaireBien", fields: [proprietaireId], references: [id])
  demandes      DemandeImmo[]
  isPublished   Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model DemandeImmo {
  id       String   @id @default(cuid())
  bienId   String
  bien     BienImmobilier @relation(fields: [bienId], references: [id])
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  message  String?
  statut   String   @default("EN_ATTENTE")
  createdAt DateTime @default(now())
}

// ============================================================
// MODULE 2 - TRANSFERT D'ARGENT
// ============================================================

enum ServiceTransfert {
  WAVE
  ORANGE_MONEY
  YASH_MONEY
  KAPEY
  FREE_MONEY
  EMONEY
}

enum StatutTransaction {
  EN_COURS
  SUCCES
  ECHEC
  ANNULEE
  SUSPENDUE
}

enum TypeOperationTransfert {
  DEPOT
  RETRAIT
  TRANSFERT
  PAIEMENT_FACTURE
  RECHARGE
}

model Transaction {
  id            String              @id @default(cuid())
  reference     String              @unique @default(cuid())
  agentId       String
  agent         User                @relation(fields: [agentId], references: [id])
  service       ServiceTransfert
  type          TypeOperationTransfert
  montant       Float
  frais         Float               @default(0)
  clientPhone   String
  clientNom     String?
  statut        StatutTransaction   @default(EN_COURS)
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

// ============================================================
// MODULE 3 - ALIMENTATION GENERALE
// ============================================================

model CategorieAlimentation {
  id       String    @id @default(cuid())
  nom      String
  articles ArticleAlimentation[]
}

model ArticleAlimentation {
  id          String   @id @default(cuid())
  nom         String
  description String?
  prix        Float
  stock       Int      @default(0)
  unite       String   @default("unité")
  image       String?
  categorieId String
  categorie   CategorieAlimentation @relation(fields: [categorieId], references: [id])
  lignesVente LigneVente[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum StatutVente {
  OUVERTE
  FERMEE
  ANNULEE
}

model VenteAlimentation {
  id          String    @id @default(cuid())
  reference   String    @unique @default(cuid())
  caissier    User      @relation(fields: [caissierNodeId], references: [id])
  caissierNodeId String
  total       Float
  statut      StatutVente @default(OUVERTE)
  modePaiement String    @default("ESPECES")
  lignes      LigneVente[]
  createdAt   DateTime  @default(now())
}

model LigneVente {
  id        String   @id @default(cuid())
  venteId   String
  vente     VenteAlimentation @relation(fields: [venteId], references: [id])
  articleId String
  article   ArticleAlimentation @relation(fields: [articleId], references: [id])
  quantite  Int
  prixUnit  Float
  total     Float
}

// ============================================================
// MODULE 4 - E-COMMERCE
// ============================================================

model CategorieEcommerce {
  id       String    @id @default(cuid())
  nom      String
  slug     String    @unique
  image    String?
  produits Produit[]
}

model Produit {
  id          String   @id @default(cuid())
  nom         String
  slug        String   @unique
  description String?
  prix        Float
  prixPromo   Float?
  stock       Int      @default(0)
  images      String[]
  categorieId String
  categorie   CategorieEcommerce @relation(fields: [categorieId], references: [id])
  lignesCommande LigneCommande[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum StatutCommande {
  EN_ATTENTE
  CONFIRMEE
  EN_PREPARATION
  EXPEDIEE
  LIVREE
  ANNULEE
  REMBOURSEE
}

enum ModePaiementCommande {
  LIVRAISON
  WAVE
  ORANGE_MONEY
}

model Commande {
  id           String               @id @default(cuid())
  reference    String               @unique @default(cuid())
  clientId     String
  client       User                 @relation(fields: [clientId], references: [id])
  lignes       LigneCommande[]
  total        Float
  statut       StatutCommande       @default(EN_ATTENTE)
  modePaiement ModePaiementCommande @default(LIVRAISON)
  adresseLivraison String
  villeLivraison   String
  telephoneClient  String
  notesClient  String?
  paiementRef  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model LigneCommande {
  id        String  @id @default(cuid())
  commandeId String
  commande  Commande @relation(fields: [commandeId], references: [id])
  produitId String
  produit   Produit @relation(fields: [produitId], references: [id])
  quantite  Int
  prixUnit  Float
  total     Float
}

// ============================================================
// MODULE 5 - LIVRAISON
// ============================================================

enum StatutLivraison {
  EN_ATTENTE
  ACCEPTEE
  EN_ROUTE_COLLECTE
  COLLECTE
  EN_ROUTE_LIVRAISON
  LIVREE
  ANNULEE
  ECHEC
}

model ZoneLivraison {
  id          String     @id @default(cuid())
  nom         String
  description String?
  prix        Float
  isActive    Boolean    @default(true)
  livraisons  Livraison[]
}

model Livraison {
  id               String         @id @default(cuid())
  reference        String         @unique @default(cuid())
  clientId         String
  client           User           @relation("ClientLivraison", fields: [clientId], references: [id])
  livreurId        String?
  livreur          User?          @relation("LivreurLivraison", fields: [livreurId], references: [id])
  zoneId           String?
  zone             ZoneLivraison? @relation(fields: [zoneId], references: [id])
  adresseCollecte  String
  latCollecte      Float?
  lngCollecte      Float?
  adresseDest      String
  latDest          Float?
  lngDest          Float?
  description      String?
  prix             Float
  statut           StatutLivraison @default(EN_ATTENTE)
  livreurLat       Float?         // position temps réel
  livreurLng       Float?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

// ============================================================
// SECURITE & AUDIT
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // ex: "TRANSACTION_CREATE", "LOGIN", "USER_BAN"
  entity    String?  // ex: "Transaction", "User"
  entityId  String?
  metadata  Json?    // données supplémentaires
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}
