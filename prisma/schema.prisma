generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISEUR
  AGENT
  GERANT
  CAISSIER
  PROPRIETAIRE
  LIVREUR
  CLIENT
}

enum UserStatus {
  ACTIVE
  PENDING
  BANNED
  SUSPENDED
}

enum StatutTransaction {
  EN_COURS
  SUCCES
  ECHEC
  ANNULEE
}

enum TypeTransaction {
  DEPOT
  RETRAIT
  TRANSFERT
  PAIEMENT_FACTURE
  RECHARGE
}

enum ServiceMobile {
  WAVE
  ORANGE_MONEY
  YASH_MONEY
  KAPEY
  FREE_MONEY
  EMONEY
}

enum StatutCommande {
  EN_ATTENTE
  CONFIRMEE
  EN_PREPARATION
  EXPEDIEE
  LIVREE
  ANNULEE
}

enum StatutLivraison {
  EN_ATTENTE
  ACCEPTEE
  EN_ROUTE_COLLECTE
  COLLECTE
  EN_ROUTE_LIVRAISON
  LIVREE
  ANNULEE
}

enum StatutBien {
  DISPONIBLE
  LOUE
  VENDU
  RESERVE
  INDISPONIBLE
}

enum TypeBien {
  APPARTEMENT
  VILLA
  STUDIO
  BUREAU
  COMMERCE
  TERRAIN
  ENTREPOT
}

// ─── USER ────────────────────────────────────────────────────────────────────

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  emailVerified DateTime?
  phone         String?     @unique
  password      String?
  image         String?
  role          Role        @default(CLIENT)
  status        UserStatus  @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  accounts        Account[]
  sessions        Session[]
  transactions    Transaction[]
  ventesAgent     VenteAlimentation[] @relation("CaissierVente")
  commandesClient Commande[]          @relation("ClientCommande")
  livraisonsClient Livraison[]        @relation("ClientLivraison")
  livraisonsLivreur Livraison[]       @relation("LivreurLivraison")
  biensProprietaire BienImmobilier[]  @relation("ProprietaireBien")
  auditLogs       AuditLog[]

  @@index([email])
  @@index([role])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── TRANSFERT D'ARGENT ──────────────────────────────────────────────────────

model Transaction {
  id          String             @id @default(cuid())
  service     ServiceMobile
  type        TypeTransaction
  montant     Float
  clientPhone String
  clientNom   String?
  notes       String?
  statut      StatutTransaction   @default(EN_COURS)
  agentId     String
  agent       User               @relation(fields: [agentId], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([agentId])
  @@index([service])
  @@index([createdAt])
}

// ─── ALIMENTATION ────────────────────────────────────────────────────────────

model CategorieAlimentation {
  id       String                 @id @default(cuid())
  nom      String                 @unique
  articles ArticleAlimentation[]
}

model ArticleAlimentation {
  id          String                @id @default(cuid())
  nom         String
  prix        Float
  stock       Int                   @default(0)
  unite       String                @default("unité")
  isActive    Boolean               @default(true)
  categorieId String?
  categorie   CategorieAlimentation? @relation(fields: [categorieId], references: [id])
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  lignesVente LigneVente[]

  @@index([categorieId])
  @@index([isActive])
}

model VenteAlimentation {
  id           String   @id @default(cuid())
  total        Float
  modePaiement String   @default("ESPECES")
  statut       String   @default("FERMEE")
  caissierNodeId String
  caissier     User     @relation("CaissierVente", fields: [caissierNodeId], references: [id])
  lignes       LigneVente[]
  createdAt    DateTime @default(now())

  @@index([caissierNodeId])
  @@index([createdAt])
}

model LigneVente {
  id        String              @id @default(cuid())
  venteId   String
  articleId String
  quantite  Int
  prixUnit  Float
  total     Float
  vente     VenteAlimentation   @relation(fields: [venteId], references: [id], onDelete: Cascade)
  article   ArticleAlimentation @relation(fields: [articleId], references: [id])
}

// ─── E-COMMERCE ──────────────────────────────────────────────────────────────

model CategorieEcommerce {
  id       String    @id @default(cuid())
  nom      String
  slug     String    @unique
  image    String?
  produits Produit[]
}

model Produit {
  id          String              @id @default(cuid())
  nom         String
  slug        String              @unique
  description String?             @db.Text
  prix        Float
  prixPromo   Float?
  stock       Int                 @default(0)
  images      String[]            @default([])
  isActive    Boolean             @default(true)
  categorieId String?
  categorie   CategorieEcommerce? @relation(fields: [categorieId], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  lignesCommande LigneCommande[]

  @@index([categorieId])
  @@index([slug])
  @@index([isActive])
}

model Commande {
  id               String         @id @default(cuid())
  clientId         String
  client           User           @relation("ClientCommande", fields: [clientId], references: [id])
  total            Float
  modePaiement     String
  statut           StatutCommande @default(EN_ATTENTE)
  adresseLivraison String
  villeLivraison   String
  telephoneClient  String
  notesClient      String?
  lignes           LigneCommande[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([clientId])
  @@index([statut])
  @@index([createdAt])
}

model LigneCommande {
  id        String   @id @default(cuid())
  commandeId String
  produitId  String
  quantite   Int
  prixUnit   Float
  total      Float
  commande   Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produit    Produit  @relation(fields: [produitId], references: [id])
}

// ─── LIVRAISON ────────────────────────────────────────────────────────────────

model ZoneLivraison {
  id          String      @id @default(cuid())
  nom         String      @unique
  description String?
  prix        Float
  isActive    Boolean     @default(true)
  livraisons  Livraison[]
}

model Livraison {
  id              String         @id @default(cuid())
  clientId        String
  client          User           @relation("ClientLivraison", fields: [clientId], references: [id])
  livreurId       String?
  livreur         User?          @relation("LivreurLivraison", fields: [livreurId], references: [id])
  zoneId          String?
  zone            ZoneLivraison? @relation(fields: [zoneId], references: [id])
  adresseCollecte String
  adresseDest     String
  latCollecte     Float?
  lngCollecte     Float?
  latDest         Float?
  lngDest         Float?
  livreurLat      Float?
  livreurLng      Float?
  description     String?
  prix            Float
  statut          StatutLivraison @default(EN_ATTENTE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([clientId])
  @@index([livreurId])
  @@index([statut])
}

// ─── IMMOBILIER ──────────────────────────────────────────────────────────────

model BienImmobilier {
  id             String        @id @default(cuid())
  titre          String
  description    String?       @db.Text
  type           TypeBien
  statut         StatutBien    @default(DISPONIBLE)
  prixLoyer      Float?
  prixVente      Float?
  surface        Float?
  nbChambres     Int?
  nbSallesDeBain Int?
  adresse        String
  ville          String        @default("Dakar")
  quartier       String?
  latitude       Float?
  longitude      Float?
  images         String[]      @default([])
  isActive       Boolean       @default(true)
  proprietaireId String
  proprietaire   User          @relation("ProprietaireBien", fields: [proprietaireId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  demandesVisite DemandeVisite[]

  @@index([proprietaireId])
  @@index([statut])
  @@index([type])
  @@index([ville])
}

model DemandeVisite {
  id        String   @id @default(cuid())
  bienId    String
  bien      BienImmobilier @relation(fields: [bienId], references: [id], onDelete: Cascade)
  nomClient String
  telClient String
  emailClient String?
  message   String?
  dateVisite DateTime?
  statut    String   @default("EN_ATTENTE")
  createdAt DateTime @default(now())

  @@index([bienId])
}

// ─── SÉCURITÉ ─────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
